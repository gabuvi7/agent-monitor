# Where Agent Monitor stores/read logs.
# Relative paths are resolved from the repository root by the UI/install script.
AGENT_MONITOR_LOG_ROOT=./logs

# Where the install script writes the OpenCode plugin copy.
AGENT_MONITOR_PLUGIN_TARGET=~/.config/opencode/plugins/subagent-tracer.ts

# Runtime env read by the globally installed plugin.
AGENT_MONITOR_RUNTIME_ENV=~/.config/agent-monitor/.env
